CLOUDFLARE_TUNNEL_TOKEN=<token from Cloudflare Zero Trust>

# GitHub OAuth App credentials (required for Claude.ai Remote MCP)
GITHUB_CLIENT_ID=<GitHub OAuth App client ID>
GITHUB_CLIENT_SECRET=<GitHub OAuth App client secret>

# Public URL of this server (used for OAuth redirect URIs)
MCP_BASE_URL=https://<subdomain>.<domain>
